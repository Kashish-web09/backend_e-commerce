<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShoeHub</title>
<script src="https://kit.fontawesome.com/21141911a4.js" crossorigin="anonymous"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>

<body>

<!-- ================= NAVBAR ================= -->
<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/index.html">ShoeHub</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
            <ul class="navbar-nav align-items-center">
                <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="pages/product.html">Products</a></li>
                <li class="nav-item"><a class="nav-link" href="/pages/contact_us.html">Contact</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Cart</a></li>
             <li class="nav-item ms-3"> <a href="/pages/login.html">  <li class="nav-item ms-3">
                    <button class="btn btn-dark btn-sm">Login</button>
                </li></a>
            </ul>
        </div>
    </div>

</nav>
<section class="cart-page bg-light py-5">
<div class="container">

    <h2 class="fw-bold mb-4 text-center">Shopping Cart</h2>

    <div class="table-responsive shadow-sm bg-white p-4 rounded">
        <table class="table align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Subtotal</th>
                    <th>Remove</th>
                </tr>
            </thead>
            <tbody id="cartItems">

            </tbody>
        </table>
    </div>

    <div class="text-end mt-4">
        <h4>Total: $ <span id="cartTotal">0</span></h4>
        <a href="./checkout.html" class="btn btn-warning mt-3">
            Proceed to Checkout
        </a>
    </div>

</div>
</section>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="../js/cart.js"></script>
</body>
</html>