<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShoeHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
    <script src="https://kit.fontawesome.com/21141911a4.js" crossorigin="anonymous"></script>
</head>
<body>

<!-- ================= NAVBAR ================= -->
<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
    <div class="container">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
            <ul class="navbar-nav align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="/">Home</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- ================= FORGOT PASSWORD SECTION ================= -->
<section class="d-flex align-items-center justify-content-center" style="min-height: 90vh;">
    <div class="card shadow-lg p-4 rounded-4" style="max-width: 450px; width:100%;">
        
        <div class="text-center mb-4">
            <h2 class="fw-bold">Forgot Password?</h2>
            <p class="text-muted">Enter your registered email to reset your password</p>
        </div>

        <form action="/forgotPass" method="post">
            <div class="mb-3">
                <input type="email" name="email" class="form-control  form-control-lg" placeholder="Email Address" required>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-warning btn-lg">
                    Send Reset Link
                </button>
            </div>
        </form>

        <div class="text-center">
            <a href="/login" class="text-decoration-none text-dark">
                <i class="fa-solid fa-arrow-left"></i> Back to Login
            </a>
        </div>

        <div class="text-center mt-3">
            <span class="text-muted">Remember your password? </span>
            <a href="/login" class="text-warning fw-bold text-decoration-none">
                Login here
            </a>
        </div>

    </div>
</section>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>