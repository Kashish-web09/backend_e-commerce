<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShoeHub</title>
<script src="https://kit.fontawesome.com/21141911a4.js" crossorigin="anonymous"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>

<body>

<!-- ================= NAVBAR ================= -->
<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/index.html">ShoeHub</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
            <ul class="navbar-nav align-items-center">
                <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="pages/product.html">Products</a></li>
                <li class="nav-item"><a class="nav-link" href="/pages/contact_us.html">Contact</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Cart</a></li>
             <li class="nav-item ms-3"> <a href="/pages/login.html">  <li class="nav-item ms-3">
                    <button class="btn btn-dark btn-sm">Login</button>
                </li></a>
            </ul>
        </div>
    </div>
</nav>
<div class="container text-center product-section">
    <div class="row">
        <div class="col-md-6 text-center">
<img src="../assets/mens_footwear_img/new_balance_360" alt="/" class="img-fluid main-img" id="mainImage" >
        </div>
    </div>
    <div class="thumb-container mt-3">
          <img src="../assets/mens_footwear_img/nike_cour_low_vision2.webp" class="thumb">
        <img src="../assets/mens_footwear_img/nike_cour_low_vision2.webp" class="thumb">
        <img src="../assets/mens_footwear_img/nike jordan" class="thumb">
    </div>
</div>
<div class="col-md-6">
    <h2>New Balance 360</h2>
    <h4 class="text-success">$99.99</h4>
    <p>Comfortable running shoes for everyday use.</p>
    <button class="btn btn-dark w-100">Add to Cart</button>
</div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const mainImage = document.getElementById('mainImage');
const thumbs = document.querySelectorAll('.thumb');
thumbs.forEach(img=>{
    img.addEventListener('click',()=>{
        mainImage.src=img.src;
    });
});
</script>
</body>
</html>