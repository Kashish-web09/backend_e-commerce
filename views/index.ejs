    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<!-- ================= NAVBAR ================= -->
<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/pages/about_us.html">ShoeHub</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
            <ul class="navbar-nav align-items-center">
                <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
                <li class="nav-item"><a class="nav-link" href="/pages/wishlist.html">Wishlist</a></li>
                <li class="nav-item"><a class="nav-link" href="/pages/cart.html">Cart</a></li>
            <li class="nav-item ms-3">
                <a href='/login'>
                    <button class="btn btn-dark btn-sm">Login</button></a>
                </li>
            
            </ul>
        </div>
    </div>
</nav>


<!-- ================= HERO SECTION ================= -->
<section class="bg-light py-5"> 
    <div class="container">
         <div class="row align-items-center">
             <div class="col-md-6"> 
                <h1 class="fw-bold">Find Your Perfect Pair</h1> 
                <p>Discover the latest trends in footwear. Shop the best collection of stylish shoes.</p> 
                <button class="btn btn-warning">Shop Now</button> </div>
                 <div class="col-md-6 d-flex justify-content-center"> 
                    <img src="/images/banner_img/banner_img1.jfif" class="img-fluid" style="max-height:250px;">
                 </div> 
                </div>
             </div> 
            </section>


<!-- ================= NEW ARRIVALS ================= -->
<section class="py-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">New Arrivals</h2>
            <button class="btn btn-dark btn-sm px-4">View All</button>
        </div>

        <div class="row g-4">

            <!-- Card Template -->
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <img src="/images/mens_footwear_img/nike jordan"
                         class="card-img-top" alt="Nike">
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">Nike Air Jordan 4</h5>
                        <p class="card-price">$120</p>
                        <a href="#" class="btn btn-warning mt-auto w-100">Add to Cart</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <img src="/images/womens_footwear_img/adidas"
                         class="card-img-top" alt="Adidas">
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">Adidas Supernova</h5>
                        <p class="card-price">$98.20</p>
                        <a href="#" class="btn btn-warning mt-auto w-100">Add to Cart</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <img src="/images/mens_footwear_img/puma_X"
                         class="card-img-top" alt="Puma">
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">Puma X-Ray Sneakers</h5>
                        <p class="card-price">$95.00</p>
                        <a href="#" class="btn btn-warning mt-auto w-100">Add to Cart</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <img src="/images/womens_footwear_img/boots"
                         class="card-img-top" alt="Boots">
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">Vegan Biker Boots</h5>
                        <p class="card-price">$31.95</p>
                        <a href="#" class="btn btn-warning mt-auto w-100">Add to Cart</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>


<!-- ================= BEST SELLER ================= -->
<section class="py-5 bg-light">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Best Seller</h2>
            <button class="btn btn-dark btn-sm px-4">View All</button>
        </div>

        <div class="row g-4">

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <img src="/images/mens_footwear_img/new_balance_360"
                         class="card-img-top" alt="New Balance">
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">New Balance 370</h5>
                        <p class="card-price">$63.00</p>
                        <a href="#" class="btn btn-warning mt-auto w-100">View Product</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <img src="/images/mens_footwear_img/puma_paliramo"
                         class="card-img-top" alt="Puma">
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">Puma Palermo</h5>
                        <p class="card-price">$29.83</p>
                        <a href="#" class="btn btn-warning mt-auto w-100">View Product</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <img src="/images/mens_footwear_img/nike_full_force"
                         class="card-img-top" alt="Nike">
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">Nike Full Force Low</h5>
                        <p class="card-price">$80.71</p>
                        <a href="#" class="btn btn-warning mt-auto w-100">View Product</a>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <img src="/images/womens_footwear_img/womens_maze"
                         class="card-img-top" alt="Women Puma">
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">Mayze Leather</h5>
                        <p class="card-price">$20.22</p>
                        <a href="#" class="btn btn-warning mt-auto w-100">View Product</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>


<!-- ================= TOP BRANDS ================= -->
<section class="py-5">
    <div class="container">
        <h2 class="fw-bold mb-4">Top Brands</h2>

        <div class="row g-4 text-center brand-logo">

            <div class="col-6 col-md-3">
                <div class="brand-box">
                    <img src="/images/brand_logo_img/nike_logo.png" alt="Nike">
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="brand-box">
                    <img src="/images/brand_logo_img/adidia_logo.png" alt="Adidas">
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="brand-box">
                    <img src="/images/brand_logo_img/puma_logo.jfif" alt="Puma">
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="brand-box">
                    <img src="/images/brand_logo_img/reebook_logo.jfif" alt="Reebok">
                </div>
            </div>

        </div>
    </div>
</section>


